# Google OAuth Configuration
GOOGLE_OAUTH_CLIENT_ID=your-google-client-id-here
GOOGLE_OAUTH_CLIENT_SECRET=your-google-client-secret-here
GOOGLE_OAUTH_REDIRECT_URI=http://localhost:8080/auth/google/callback

# Twitter OAuth Configuration
TWITTER_OAUTH_CLIENT_ID=your-twitter-client-id-here
TWITTER_OAUTH_CLIENT_SECRET=your-twitter-client-secret-here
TWITTER_OAUTH_REDIRECT_URI=http://localhost:8080/auth/twitter/callback

# Database Configuration (if not in config files)
# DB_HOST=localhost
# DB_NAME=neutrino
# DB_USER=root
# DB_PASSWORD=

# Application Settings
# APP_ENV=development
# APP_DEBUG=true

