                endColor: am5.color("#674ea7"),
                startText: "Low",
                endText: "High",
                stepCount: 5,
                x: am5.p50,
                centerX: am5.p50,
                y: am5.p100,
                centerY: am5.p100,
                dy: -10
            })
        );

        polygonSeries.events.on("datavalidated", function () {
            heatLegend.set("startValue", polygonSeries.getPrivate("valueLow"));
            heatLegend.set("endValue", polygonSeries.getPrivate("valueHigh"));

            // Center Austria (adjust zoom to taste)
            chart.zoomToGeoPoint({ latitude: 47.5162, longitude: 14.5501 }, 12, true);
        });

        polygonSeries.mapPolygons.template.events.on("pointerover", (ev) => {
            const di = ev.target.dataItem;
            if (!di) return;
            const v = di.get("value");
            if (typeof v === "number") heatLegend.showValue(v);
        });

        polygonSeries.mapPolygons.template.events.on("pointerout", () => {
            heatLegend.showValue(null);
        });

        // ---- Dots with numbers ----
        const pointSeries = chart.series.push(
            am5map.MapPointSeries.new(root, {
                // Keep it explicit & future-proof
                // (not strictly required when using geometry, but harmless)
                longitudeField: "longitude",
                latitudeField: "latitude"
            })
        );

        const markerData = data
            .map(d => {
                const c = countryCenters[d.id];
                if (!c) return null;

                return {
                    id: d.id,
                    value: d.value,
                    geometry: {
                        type: "Point",
                        coordinates: [c.lon, c.lat] // IMPORTANT: [lon, lat]
                    }
                };
            })
            .filter(Boolean);

        pointSeries.data.setAll(markerData);

        pointSeries.bullets.push(function (root, series, dataItem) {
            const value = dataItem.dataContext.value ?? 0;

            // Just a number (no circle)
            const label = am5.Label.new(root, {
                text: String(value),
                centerX: am5.p50,
                centerY: am5.p50,
                fontSize: 11,
                fontWeight: "600",
                fill: am5.color(0x000000), // pick whatever contrasts your map
                // optional: make it readable on colored countries
                background: am5.RoundedRectangle.new(root, {
                    fill: am5.color(0xffffff),
                    fillOpacity: 0.7,
                    cornerRadiusTL: 0,
                    cornerRadiusTR: 0,
                    cornerRadiusBL: 0,
                    cornerRadiusBR: 0
                }),
                paddingLeft: 5,
                paddingRight: 5,
                paddingTop: 2,
                paddingBottom: 2,
                tooltipText: "{id}\nVisitors: {value.formatNumber('#,###')}"
            });

            return am5.Bullet.new(root, { sprite: label });
        });

        chart.appear(800, 100);

        window.addEventListener("beforeunload", () => root.dispose());
    });
</script>