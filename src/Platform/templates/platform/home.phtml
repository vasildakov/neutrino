<script>
    am5.ready(function () {
        const root = am5.Root.new("chart-registrations");
        root.setThemes([am5themes_Animated.new(root)]);

        // ----- Chart (MUST be created before axes/series) -----
        const chart = root.container.children.push(
            am5xy.XYChart.new(root, {
                panX: false,
                panY: false,
                wheelX: "none",
                wheelY: "none",
                layout: root.verticalLayout
            })
        );

        // X Axis (Month)
        const xAxis = chart.xAxes.push(
            am5xy.DateAxis.new(root, {
                baseInterval: { timeUnit: "month", count: 1 },
                renderer: am5xy.AxisRendererX.new(root, { minGridDistance: 40 }),
                tooltip: am5.Tooltip.new(root, {})
            })
        );

        // Show month labels like "Feb 2026"
        xAxis.get("dateFormats")["month"] = "MMM yyyy";
        xAxis.get("periodChangeDateFormats")["month"] = "MMM yyyy";

        // Y Axis (Counts)
        const yAxis = chart.yAxes.push(
            am5xy.ValueAxis.new(root, {
                renderer: am5xy.AxisRendererY.new(root, {})
            })
        );

        // ----- Visits Series (Bottom Stack) -----
        const visitsSeries = chart.series.push(
            am5xy.ColumnSeries.new(root, {
                name: "Visits",
                xAxis,
                yAxis,
                valueYField: "visits",
                valueXField: "date",
                stacked: true,
                tooltip: am5.Tooltip.new(root, {
                    labelText: "Visits: {valueY.formatNumber('#,###')}"
                })
            })
        );

        visitsSeries.columns.template.setAll({
            width: am5.percent(60),
            fill: am5.color("#674ea7"),
            stroke: am5.color("#674ea7"),
            strokeOpacity: 0.5
        });

        // ----- Registrations Series (Top Stack) -----
        const registrationsSeries = chart.series.push(
            am5xy.ColumnSeries.new(root, {
                name: "Registrations",
                xAxis,
                yAxis,
                valueYField: "registrations",
                valueXField: "date",
                stacked: true,
                tooltip: am5.Tooltip.new(root, {
                    labelText: "Registrations: {valueY.formatNumber('#,###')}"
                })
            })
        );

        registrationsSeries.columns.template.setAll({
            width: am5.percent(60),
            fill: am5.color("#e47fba"),
            stroke: am5.color("#e47fba"),
            strokeOpacity: 0.5
        });

        // Cursor
        const cursor = chart.set("cursor", am5xy.XYCursor.new(root, { xAxis }));
        cursor.lineY.set("visible", false);

        // Legend
        const legend = chart.children.push(
            am5.Legend.new(root, {
                centerX: am5.p50,
                x: am5.p50,
                marginTop: 12
            })
        );
        // const legend = chart.children.push(
        //     am5.Legend.new(root, {
        //         centerX: am5.p50,
        //         x: am5.p50
        //     })
        // );
        legend.data.setAll(chart.series.values);

        // ----- Load data AFTER series exist -----
        fetch("/platform/analytics/visits?months=12")
            .then(r => {
                if (!r.ok) throw new Error("Failed to load /platform/analytics/visits");
                return r.json();
            })
            .then(data => {
                visitsSeries.data.setAll(data);
                registrationsSeries.data.setAll(data);

                // Animate after async load
                visitsSeries.appear(800);
                registrationsSeries.appear(800);
                chart.appear(800, 100);
            })
            .catch(console.error);

        window.addEventListener("beforeunload", () => root.dispose());
    });
</script>




<!-- BEGIN Browser distribution chart -->
<script>
    am5.ready(function () {
        const root = am5.Root.new("chart-browser");
        root.setThemes([am5themes_Animated.new(root)]);

        // Chart
        const chart = root.container.children.push(
            am5percent.PieChart.new(root, {
                layout: root.verticalLayout,
                innerRadius: am5.percent(60) // donut
            })
        );

        // Series
        const series = chart.series.push(
            am5percent.PieSeries.new(root, {
                name: "Browsers",
                valueField: "value",
                categoryField: "browser",
                alignLabels: false
            })
        );

        async function loadBrowserData() {
            try {
                const response = await fetch("/platform/analytics/browser?days=30");
                if (!response.ok) throw new Error("API error");

                const data = await response.json();
                series.data.setAll(data);

            } catch (e) {
                console.error(e);
            }
        }
        loadBrowserData();

        // Tooltips
        series.slices.template.setAll({
            tooltipText: "{category}: {value.formatNumber('#,###')} ({valuePercentTotal.formatNumber('0.0')}%)",
            strokeOpacity: 0.4
        });

        // Labels inside
        series.labels.template.setAll({
            text: "{valuePercentTotal.formatNumber('0.0')}%",
            oversizedBehavior: "truncate",
            fillOpacity: 0.9
        });

        series.ticks.template.setAll({
            visible: false
        });

        // Legend
        const legend = chart.children.push(
            am5.Legend.new(root, {
                centerX: am5.p50,
                x: am5.p50,
                marginTop: 20
            })
        );

        legend.data.setAll(series.dataItems);

        // Animate
        series.appear(800, 100);

        // Cleanup
        window.addEventListener("beforeunload", () => root.dispose());
    });
</script>
