    <script src="<?= $this->asset('sandbox/assets/js/plugins.js') ?>"></script>
    <script src="<?= $this->asset('sandbox/assets/js/theme.js') ?>"></script>

    <script>
        (function () {
            const CONSENT_COOKIE = 'neutrino_consent';

            function getCookie(name) {
                const m = document.cookie.match(new RegExp('(^| )' + name + '=([^;]+)'));
                return m ? decodeURIComponent(m[2]) : null;
            }

            function hasConsentToken() {
                return !!getCookie(CONSENT_COOKIE);
            }

            function showBanner() {
                document.getElementById('consent-banner')?.classList.remove('d-none');
            }

            function hideBanner() {
                document.getElementById('consent-banner')?.classList.add('d-none');
            }

            function activateScripts(category) {
                document.querySelectorAll(`script[type="text/plain"][data-consent="${category}"]`)
                    .forEach(el => {
                        const s = document.createElement('script');
                        // Copy inline content
                        if (el.textContent) s.text = el.textContent;
                        // Copy src if you prefer external scripts
                        const src = el.getAttribute('data-src');
                        if (src) s.src = src;
                        document.head.appendChild(s);
                    });
            }

            function deleteTrackingCookies() {
                // Add your actual cookies here:
                const names = ['_ga', '_gid', '_fbp'];
                names.forEach(n => document.cookie = `${n}=; Path=/; Expires=Thu, 01 Jan 1970 00:00:00 GMT; SameSite=Lax`);
            }

            function enforceConsent(purposes) {
                if (purposes.analytics) activateScripts('analytics');
                if (purposes.marketing) activateScripts('marketing');

                // On withdrawal: stop & delete
                if (!purposes.analytics && !purposes.marketing) {
                    deleteTrackingCookies();
                    // Examples: set global flags for your tracking layer
                    window.__analyticsEnabled = false;
                    window.__marketingEnabled = false;
                }
            }

            async function saveConsent(purposes) {
                const res = await fetch('/api/consent/save', {
                    method: 'POST',
                    headers: {'Content-Type': 'application/json'},
                    body: JSON.stringify({purposes})
                });
                if (!res.ok) throw new Error('Consent save failed');
                const json = await res.json();
                enforceConsent(json.purposes);
                hideBanner();
            }

            async function revokeConsent() {
                const res = await fetch('/api/consent/revoke', { method: 'POST' });
                if (!res.ok) throw new Error('Consent revoke failed');
                const json = await res.json();
                enforceConsent(json.purposes);
                hideBanner();
            }

            // boot
            if (!hasConsentToken()) {
                showBanner();
            } else {
                // If you want, read purposes via server-rendered attribute, or keep it simple:
                // We can’t decode signed cookie client-side (by design), so we just assume:
                // - server will enforce, and optional scripts won't exist unblocked.
                // If you want client enforcement too, you can add a tiny endpoint /api/consent/me
                // that returns current purposes.
            }

            document.getElementById('consent-accept')?.addEventListener('click', () => {
                saveConsent({essential:true, functional:true, analytics:true, marketing:true}).catch(console.error);
            });

            document.getElementById('consent-reject')?.addEventListener('click', () => {
                revokeConsent().catch(console.error);
            });

            document.getElementById('consent-settings')?.addEventListener('click', () => {
                // optional: open a modal settings UI that loads /api/consent/config
                // keep banner visible; implement modal later
                alert('Open settings modal (load /api/consent/config).');
            });

        })();
    </script>

</body>
</html>

