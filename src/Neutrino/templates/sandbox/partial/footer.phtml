<!-- Cookie revoke button. Move it to consent.js -->
<div class="cookie-revoke d-none" id="cookie-revoke-msg"></div>
<script>
    (function () {
        function setText(msg, isError = false) {
            const el = document.getElementById('cookie-revoke-msg');
            if (!el) return;

            el.textContent = msg;
            el.classList.remove('d-none', 'text-danger', 'text-success');
            el.classList.add(isError ? 'text-danger' : 'text-success');

            window.setTimeout(() => {
                el.classList.add('d-none');
            }, 3000);
        }

        function stopTrackingNow() {
            // Add your specific tracking shutdown here if needed
            // Example GA4:
            // window['ga-disable-G-XXXXXXXXXX'] = true;

            // Delete common tracking cookies (double safety; backend also sets expirations)
            ['_ga','_gid','_gat','_fbp','_gcl_au'].forEach(name => {
                document.cookie = `${name}=; Path=/; Expires=Thu, 01 Jan 1970 00:00:00 GMT; SameSite=Lax`;
            });
        }

        async function revokeConsent() {
            const res = await fetch('/api/consent/revoke', {
                method: 'POST',
                headers: { 'Accept': 'application/json' }
            });

            if (!res.ok) {
                throw new Error(`Revoke failed (${res.status})`);
            }

            // Response sets cookies via headers; body just confirms purposes.
            const json = await res.json();
            stopTrackingNow();

            // If your site injects tags conditionally server-side, a reload ensures they're gone.
            // You can skip reload if you already block scripts via type="text/plain".
            // location.reload();

            return json;
        }

        document.addEventListener('DOMContentLoaded', () => {
            const btn = document.getElementById('cookie-revoke');
            if (!btn) return;

            btn.addEventListener('click', async (e) => {
                e.preventDefault();

                btn.setAttribute('aria-busy', 'true');
                btn.classList.add('disabled');

                try {
                    await revokeConsent();
                    setText('Consent withdrawn. Optional cookies disabled.');
                } catch (err) {
                    console.error(err);
                    setText('Could not withdraw consent. Please try again.', true);
                } finally {
                    btn.removeAttribute('aria-busy');
                    btn.classList.remove('disabled');
                }
            });
        });
    })();
</script>