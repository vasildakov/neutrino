<script>
    // Form validation
    (function() {
        'use strict';

        console.log('Checkout form script loaded');

        const forms = document.querySelectorAll('.needs-validation');
        console.log('Found forms:', forms.length);

        Array.from(forms).forEach(form => {
            console.log('Attaching submit handler to form:', form.id);
            console.log('Form action:', form.action);
            console.log('Form method:', form.method);

            form.addEventListener('submit', event => {
                console.log('Form submit event triggered');
                console.log('Form validity:', form.checkValidity());

                if (!form.checkValidity()) {
                    console.log('Form validation failed');
                    event.preventDefault();
                    event.stopPropagation();
                } else {
                    console.log('Form is valid, submitting...');
                    // Form will submit normally
                }
                form.classList.add('was-validated');
            }, false);
        });

        // Add click handler to button for debugging
        const submitButton = document.querySelector('button[type="submit"][form="checkout-form"]');
        if (submitButton) {
            console.log('Submit button found');
            submitButton.addEventListener('click', function(e) {
                console.log('Submit button clicked');
                e.preventDefault(); // Prevent default to manually trigger
                const form = document.getElementById('checkout-form');
                if (form.checkValidity()) {
                    console.log('Manually triggering form submit');
                    form.submit(); // Manually submit the form
                } else {
                    console.log('Form validation failed, showing errors');
                    form.classList.add('was-validated');
                    form.reportValidity();
                }
            });
        } else {
            console.log('Submit button NOT found');
        }

        // Format card number
        const cardNumber = document.getElementById('cc-number');
        if (cardNumber) {
            cardNumber.addEventListener('input', function(e) {
                let value = e.target.value.replace(/\s+/g, '');
                e.target.value = value.match(/.{1,4}/g)?.join(' ') || value;
            });
        }

        // Format expiry date
        const expiry = document.getElementById('cc-expiration');
        if (expiry) {
            expiry.addEventListener('input', function(e) {
                let value = e.target.value.replace(/\D/g, '');
                if (value.length >= 2) {
                    value = value.slice(0, 2) + '/' + value.slice(2, 4);
                }
                e.target.value = value;
            });
        }
    })();
</script>